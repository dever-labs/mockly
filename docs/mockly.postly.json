        {
          "name": "HTTP Mocks",
          "description": "Create, update, and delete HTTP mock definitions.",
          "auth": { "type": "none", "config": {} },
          "ssl": "inherit",
          "requests": [
            {
              "name": "List HTTP Mocks",
              "method": "GET",
              "url": "{{baseUrl}}/api/mocks/http",
              "protocol": "http",
              "params": [],
              "headers": [],
              "bodyType": "none",
              "bodyContent": "",
              "auth": { "type": "inherit", "config": {} },
              "ssl": "inherit",
              "description": "Returns all currently registered HTTP mocks.",
              "protocolConfig": {}
            },
            {
              "name": "Create HTTP Mock",
              "method": "POST",
              "url": "{{baseUrl}}/api/mocks/http",
              "protocol": "http",
              "params": [],
              "headers": [
                { "key": "Content-Type", "value": "application/json", "enabled": true }
              ],
              "bodyType": "json",
              "bodyContent": "{\n  \"id\": \"get-users\",\n  \"request\": {\n    \"method\": \"GET\",\n    \"path\": \"/users\"\n  },\n  \"response\": {\n    \"status\": 200,\n    \"headers\": {\n      \"Content-Type\": \"application/json\"\n    },\n    \"body\": \"[{\\\"id\\\":1,\\\"name\\\":\\\"Alice\\\"}]\"\n  }\n}",
              "auth": { "type": "inherit", "config": {} },
              "ssl": "inherit",
              "description": "Registers a new HTTP mock. If 'id' is omitted it is auto-generated.\n\nThe request.path field supports exact strings and path parameters (e.g. /users/{id}).\nThe response.body field supports Go text/template with .query, .headers, and .body context.",
              "protocolConfig": {}
            },
            {
              "name": "Update HTTP Mock",
              "method": "PUT",
              "url": "{{baseUrl}}/api/mocks/http/{{mockId}}",
              "protocol": "http",
              "params": [],
              "headers": [
                { "key": "Content-Type", "value": "application/json", "enabled": true }
              ],
              "bodyType": "json",
              "bodyContent": "{\n  \"request\": {\n    \"method\": \"GET\",\n    \"path\": \"/users\"\n  },\n  \"response\": {\n    \"status\": 200,\n    \"headers\": {\n      \"Content-Type\": \"application/json\"\n    },\n    \"body\": \"[{\\\"id\\\":1,\\\"name\\\":\\\"Alice\\\"}]\"\n  }\n}",
              "auth": { "type": "inherit", "config": {} },
              "ssl": "inherit",
              "description": "Fully replaces an HTTP mock. Set mockId in your environment or replace it in the URL.",
              "protocolConfig": {}
            },
            {
              "name": "Patch HTTP Mock",
              "method": "PATCH",
              "url": "{{baseUrl}}/api/mocks/http/{{mockId}}",
              "protocol": "http",
              "params": [],
              "headers": [
                { "key": "Content-Type", "value": "application/json", "enabled": true }
              ],
              "bodyType": "json",
              "bodyContent": "{\n  \"status\": 503,\n  \"body\": \"{\\\"error\\\":\\\"temporarily unavailable\\\"}\"\n}",
              "auth": { "type": "inherit", "config": {} },
              "ssl": "inherit",
              "description": "Partially updates the response fields of an HTTP mock (status, headers, body, delay). Useful for temporarily overriding a mock without replacing it.",
              "protocolConfig": {}
            },
            {
              "name": "Delete HTTP Mock",
              "method": "DELETE",
              "url": "{{baseUrl}}/api/mocks/http/{{mockId}}",
              "protocol": "http",
              "params": [],
              "headers": [],
              "bodyType": "none",
              "bodyContent": "",
              "auth": { "type": "inherit", "config": {} },
              "ssl": "inherit",
              "description": "Removes an HTTP mock by ID.",
              "protocolConfig": {}
            }
          ]
        },
