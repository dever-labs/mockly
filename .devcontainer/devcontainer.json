{
  "name": "Mockly",
  "image": "ghcr.io/dever-labs/devcontainers/go-dev:latest",
  "mounts": [
    "source=dever-labs-gh-config,target=/home/vscode/.config/gh,type=volume",
    "source=dever-labs-copilot,target=/home/vscode/.copilot,type=volume"
  ],

  "remoteEnv": {
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },

  "forwardPorts": [8080, 8081, 9091, 50051],
  "portsAttributes": {
    "8080": { "label": "HTTP Mocks" },
    "8081": { "label": "WebSocket Mocks" },
    "9091": { "label": "Management API + UI" },
    "50051": { "label": "gRPC Mocks" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "anthropics.claude-code",
        "golang.go"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "off",
        "go.useLanguageServer": true,
        "editor.formatOnSave": true,
        "github.copilot.enable": { "*": true },
        "[go]": {
          "editor.defaultFormatter": "golang.go"
        }
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/init.sh",
  "remoteUser": "vscode"
}
